      "source": [
        "# 1. 条件判定対象の数値を変数varに代入\n",
        "var = 10\n",
        "\n",
        "# 2. if文による条件分岐\n",
        "if var % 3 == 0 and var % 5 == 0:\n",
        "    # 3の倍数かつ5の倍数の場合\n",
        "    print(\"FizzBuzz\")\n",
        "elif var % 3 == 0:\n",
        "    # 3の倍数の場合\n",
        "    print(\"Fizz\")\n",
        "elif var % 5 == 0:\n",
        "    # 5の倍数の場合\n",
        "    print(\"Buzz\")\n",
        "else:\n",
        "    # どの場合にも該当しない場合\n",
        "    print(var)\n"
      ]
