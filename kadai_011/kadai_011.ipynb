      "source": [
        "array = [\"水\", \"金\", \"地\", \"火\", \"木\", \"土\", \"天\", \"海\", \"冥\"]\n",
        "\n",
        "# 1. forを用いて繰り返し処理\n",
        "for planet in array:\n",
        "    print(planet)\n",
        "\n",
        "# 2. whileを用いて繰り返し処理\n",
        "index = 0\n",
        "while index < len(array):\n",
        "    print(array[index])\n",
        "    index += 1\n"
      ]
