      "source": [
        "#上辺：10cm\n",
        "#下辺：20cm\n",
        "#高さ：5cm\n",
        "\n",
        "#公式：台形の面積 =（上辺＋下辺）× 高さ ÷ 2\n",
        "\n",
        "upper = 10\n",
        "lower = 20\n",
        "height = 5\n",
        "\n",
        "def calculate_trapezoid_area(u, l, h):\n",
        "    trapezoid_area = (u + l) * h / 2\n",
        "    return trapezoid_area\n",
        "\n",
        "result = calculate_trapezoid_area(upper, lower, height)\n",
        "print(str(int(result)) + \"cm²\" )"
      ]
